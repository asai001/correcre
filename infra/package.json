{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "dist/bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy:dev": "cdk deploy CorrecreDevInfraStack --profile CorreCre-Dev-Account",
    "deploy:stg": "cdk deploy CorrecreStgInfraStack --profile CorreCre-Stg-Account --require-approval never",
    "deploy:prod": "cdk deploy CorrecreProdInfraStack --profile CorreCre-Prod-Account --require-approval never",
    "seed:maintenance": "ts-node --transpile-only scripts/seed-maintenance.ts --profile CorreCre-Stg-Account",
    "seed:maintenance:reset": "ts-node --transpile-only scripts/reset-maintenance-seed.ts --profile CorreCre-Stg-Account"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "aws-cdk": "^2.1029.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1019.0",
    "@aws-sdk/credential-provider-ini": "^3.972.27",
    "@aws-sdk/lib-dynamodb": "^3.1019.0",
    "aws-cdk-lib": "^2.217.0",
    "constructs": "^10.0.0"
  }
}
